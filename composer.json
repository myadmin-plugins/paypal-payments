{
	"name": "detain/myadmin-paypal-payments",
	"type": "myadmin-plugin",
	"description": "PayPal payment processing plugin for the MyAdmin control panel, providing Express Checkout, Digital Goods, recurring payments, subscription management, IPN handling, and administrative refund tools.",
	"keywords": [
		"paypal",
		"payment",
		"billing",
		"checkout",
		"myadmin",
		"plugin"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https://my.interserver.net/"
		}
	],
	"config": {
		"bin-dir": "vendor/bin",
		"minimum-stability": "dev",
		"allow-plugins": {
			"detain/myadmin-plugin-installer": true
		}
	},
	"require": {
		"php": ">=8.2",
		"ext-soap": "*",
		"ext-curl": "*",
		"ext-mbstring": "*",
		"symfony/event-dispatcher": "^5.0|^6.0|^7.0",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminPaypal\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminPaypal\\Tests\\": "tests/"
		}
	}
}
